{
    "name": "course-professor",
    "version": "1.4.0",
    "description": "A Socratic learning assistant - teaches by asking questions instead of giving answers. Works with Claude Code, OpenCode, Gemini CLI, and other AI agents.",
    "type": "module",
    "bin": {
        "course-professor": "./bin/cli.js",
        "professor": "./bin/cli.js"
    },
    "scripts": {
        "build": "cd web/client && npm install && npm run build",
        "start": "cd web && node server.js",
        "test": "vitest",
        "prepublishOnly": "npm run build"
    },
    "files": [
        "bin/",
        "templates/",
        "shared/",
        "plugin.json",
        "web/server.js",
        "web/package.json",
        "web/package-lock.json",
        "web/dist/",
        "web/client/src/",
        "web/client/index.html",
        "web/client/package.json",
        "web/client/package-lock.json",
        "web/client/vite.config.js",
        "web/client/tailwind.config.js",
        "web/client/postcss.config.js",
        "web/client/components.json"
    ],
    "keywords": [
        "learning",
        "socratic",
        "education",
        "ai",
        "claude",
        "opencode",
        "teacher",
        "course"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/Thanhtuan96/course-builder"
    },
    "dependencies": {
        "chalk": "^5.3.0",
        "inquirer": "^9.2.23",
        "ora": "^8.1.1"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "author": "ronnie-tk",
    "license": "MIT",
    "devDependencies": {
        "vitest": "^4.1.1"
    }
}
